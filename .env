# ============================================
# 🔐 ENCODER BOT ENV CONFIG
# ============================================

# 🤖 Telegram Bot Token (From @BotFather)
BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# 👨‍💻 Admin Telegram User ID (comma separated if multiple)
ADMIN_IDS=123456789

# 💰 Payment Numbers
BKASH_NUMBER=01XXXXXXXXX
NAGAD_NUMBER=01XXXXXXXXX

# 📊 Free User Limit (per day)
FREE_LIMIT=3

# 🌐 Server Port (Render automatically sets this, but keep fallback)
PORT=10000
